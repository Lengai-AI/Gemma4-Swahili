# ──────────────────────────────────────────────────────────────────────────────
# Gemma4-Swahili — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for: GPT-4o-mini translation via Batch API (dataprep/)
# Get yours: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Used for: pushing datasets and fine-tuned models to HuggingFace Hub
# Get yours: https://huggingface.co/settings/tokens
# Required permissions: write access to your namespace
HF_TOKEN=hf_...

# ── HuggingFace Repos ────────────────────────────────────────────────────────
# Dataset repos
HF_DATASET_REPO=ngusadeep/FineTome-20k-sw
HF_DATASET_REPO_SHAREGPT=ngusadeep/FineTome-20k-sw-sharegpt

# Fine-tuned model repos
HF_MODEL_REPO_E2B=ngusadeep/gemma-4-2B-Swahili-llm
HF_MODEL_REPO_E24=ngusadeep/gemma-4-24B-Swahili-llm
